<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="University.UI.DepartmentsPage"
    Title="Кафедри">

    <VerticalStackLayout Padding="16" Spacing="12">

        <Label Text="Список кафедр"
               FontSize="24"
               FontAttributes="Bold" />

        <CollectionView x:Name="DepartmentsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12"
                           Margin="0,6"
                           CornerRadius="12">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDepartmentTapped" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>

                            <!-- Пока оставляем enum как есть (безопасно) -->
                            <Label Text="{Binding Type}"
                                   FontSize="14"
                                   Opacity="0.7"/>
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>